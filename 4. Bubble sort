def bubble_sort(arr):
    n = len(arr)
    for i in range(n):
        for j in range(n-i-1):
            if arr[j] > arr[j+1]:
                arr[j], arr[j+1] = arr[j+1], arr[j]
    return arr

data = [5, 3, 8, 1, 2]
hasil = bubble_sort(data)

print("Data sebelum sorting:", [5, 3, 8, 1, 2])
print("Data setelah sorting:", hasil)
